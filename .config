conky.config = {
    background = true,
    use_xft = true,
    font = 'DejaVu Sans Mono:size=10',
    xftalpha = 0.9,
    update_interval = 1,

    own_window = true,
    own_window_type = 'dock',
    own_window_transparent = true,
    own_window_argb_visual = true,
    own_window_argb_value = 0,
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',

    double_buffer = true,
    draw_shades = false,
    draw_outline = false,
    draw_borders = false,

    default_color = '#e0e0e0',
    color1 = '#8ACE00',
    color2 = '#a0a0a0',

    alignment = 'top_right',
    gap_x = 20,
    gap_y = 40,

    cpu_avg_samples = 2,
    net_avg_samples = 2,
};

conky.text = [[
${alignc}${font DejaVu Sans Mono:bold:size=12}Juls-Xi${font}
$hr
${alignc}${color1}${time %A, %B %d}
${alignc}${font DejaVu Sans Mono:size=18}${time %H:%M}${font}

${color1}SYSTEM ${hr 1}
Uptime: $uptime
Kernel: $kernel

${color1}CPU ${hr 1}
Usage: $cpu% ${cpubar 6}
Core1: ${cpu cpu1}% ${cpubar cpu1 4}
Core2: ${cpu cpu2}% ${cpubar cpu2 4}

${color1}MEMORY ${hr 1}
RAM: $mem / $memmax ($memperc%) ${membar 6}
Swap: $swap / $swapmax ($swapperc%) ${swapbar 6}

${color1}DISK ${hr 1}
 /        ${fs_used /}/${fs_size /} ${fs_bar 6 /}
 /home    ${fs_used /home}/${fs_size /home} ${fs_bar 6 /home}
 /data    ${fs_used /mnt/storage}/${fs_size /mnt/storage} ${fs_bar 6 /mnt/storage}

${color1}NETWORK ${hr 1}
Down: ${downspeed wlp0s16f0u2} k/s
Up: ${upspeed wlp0s16f0u2} k/s

${color1}TOP PROCESSES ${hr 1}
${top name 1} ${top cpu 1}%
${top name 2} ${top cpu 2}%
${top name 3} ${top cpu 3}%
]];